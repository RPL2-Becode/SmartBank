# SmartBank Frontend Configuration
# Copy this file to .env and fill in your values

# API Base URL — point to your backend server
# Default fallback used by src/api/client.ts when this env is unset:
#   http://127.0.0.1:5000/smartbank
VITE_API_BASE_URL=http://127.0.0.1:5000/smartbank

# Optional: For production
# VITE_API_BASE_URL=https://api.yourdomain.com/smartbank
