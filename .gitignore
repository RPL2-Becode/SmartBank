# Root Gitignore for SmartBank Parent Workspace

# Dependency directories
node_modules/
**/node_modules/

# Local env files
.env
**/.env
.env*.local
local.properties
**/local.properties

# Build artifacts
dist/
**/dist/
build/
**/build/
coverage/
**/coverage/
*.tsbuildinfo
**/*.tsbuildinfo
*.apk
*.aab
*.ap_
*.dex

# Logs and debug files
*.log
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
hs_err_pid*
*.hprof

# System files
.DS_Store
Thumbs.db

# IDE configuration
.vscode/
.idea/
**/.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.iml

# Duplicate local progress logs
wallet/PROGRESS.md

# Android / Gradle local state
.gradle/
**/.gradle/
.kotlin/
**/.kotlin/
.externalNativeBuild/
**/.externalNativeBuild/
.cxx/
**/.cxx/
captures/
**/captures/
android-wallet/gradle/gradle-daemon-jvm.properties

# Codex / AI generated scratch workspaces
.agents/
docx-render-check/
*.tmp.docx
*_Temuan_Tambahan.docx

# Raw academic context exports duplicated from tracked context summaries
Context Ekosistem RPL II/
context/*.csv
context/*.xlsx

docs/
.hermes/
.claude/
.github/
.commandcode/
AUDIT_REPORT_v2.md
AUDIT_REPORT.md
CLAUDE.md
